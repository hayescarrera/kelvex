# ColdGrid Environment Variables
# Copy this to .env and fill in values

# ── Runtime ──────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Database ─────────────────────────────────────
POSTGRES_USER=coldgrid
POSTGRES_PASSWORD=coldgrid_dev
POSTGRES_DB=coldgrid
DATABASE_URL=postgresql+asyncpg://coldgrid:coldgrid_dev@db:5432/coldgrid

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth & Security ──────────────────────────────
# REQUIRED in production — set a long random value (e.g. openssl rand -hex 32)
SECRET_KEY=dev-secret-key-change-in-production

# REQUIRED in production — Fernet key for encrypting integration credentials
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# ── Rate Limiting ────────────────────────────────
AUTH_RATE_LIMIT_PER_MINUTE=5
API_RATE_LIMIT_PER_MINUTE=100

# ── CORS ─────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# ── External APIs ────────────────────────────────
# OpenEI API key (free, get one at https://api.openei.org/)
OPENEI_API_KEY=

# ── Email Notifications (SMTP) ───────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@coldgrid.io

# ── SMS Notifications (Twilio) ───────────────────
# Sign up at https://www.twilio.com — free trial includes test numbers
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Monitoring (optional) ────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
HEALTHCHECK_STRICT=false
