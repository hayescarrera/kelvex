# ── Required ─────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# Change from default immediately
POSTGRES_PASSWORD=

# Comma-separated — your actual domain(s)
CORS_ORIGINS=https://app.kelvex.io

# ── Invite-only registration ──────────────────────────────────────────────
# Passed as ?invite=<token> on the register endpoint
# Generate: openssl rand -hex 16
INVITE_SECRET=

# ── Email (alerts, invites, password resets, ops digest) ─────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@kelvex.io
# Daily fleet-health digest to the Kelvex operator. Empty disables.
OPS_ALERT_EMAIL=

# ── Backups ───────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=14
# Off-site: set an rclone remote (e.g. b2:kelvex-backups/db) and
# RCLONE_CONFIG_PATH to an rclone.conf on the host. Local-only until then.
BACKUP_RCLONE_REMOTE=
#RCLONE_CONFIG_PATH=/root/.config/rclone/rclone.conf

# ── Optional ─────────────────────────────────────────────────────────────
OPENEI_API_KEY=
SENTRY_DSN=
AUTH_RATE_LIMIT_PER_MINUTE=5
API_RATE_LIMIT_PER_MINUTE=100
AGENT_RATE_LIMIT_PER_MINUTE=600
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
